<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigator_Engine | Stack Logic</title>
    <style>
        :root { 
            --primary: #0044ff; 
            --bg: #f0f2f5;
            --glass: rgba(255, 255, 255, 0.8);
            --border: rgba(0, 0, 0, 0.05);
            --text: #1d1d1f;
        }
        
        * { cursor: none !important; margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            background: linear-gradient(180deg, #ffffff 0%, #e5e7eb 100%);
            color: var(--text); 
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        /* NEON BLUE PRECISION CURSOR */
        #custom-cursor {
            width: 10px; height: 10px; background: var(--primary); border-radius: 50%;
            position: fixed; pointer-events: none; z-index: 10001;
            transform: translate(-50%, -50%); box-shadow: 0 0 15px rgba(0, 68, 255, 0.4);
            transition: transform 0.1s ease-out;
        }

        .engine-container {
            width: 1100px;
            background: var(--glass);
            backdrop-filter: blur(30px);
            border-radius: 40px;
            padding: 50px;
            border: 1px solid var(--border);
            box-shadow: 0 40px 100px rgba(0,0,0,0.08);
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 40px;
        }

        /* HEADER AREA */
        .sidebar h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 10px; }
        .sidebar p { font-size: 0.75rem; color: #8e8e93; font-family: monospace; margin-bottom: 40px; }

        /* INPUT AREA */
        .nav-controls label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #666; display: block; margin-bottom: 10px; }
        input {
            width: 100%; padding: 18px; border: 1px solid #ddd; border-radius: 15px;
            background: #fff; margin-bottom: 20px; outline: none; font-size: 1rem;
        }

        .btn-group { display: flex; gap: 10px; margin-bottom: 30px; }
        .btn {
            flex: 1; padding: 15px; border: none; border-radius: 12px;
            font-weight: 700; font-size: 0.8rem; transition: 0.3s;
        }
        .btn-push { background: var(--primary); color: #fff; }
        .btn-nav { background: #fff; border: 1px solid #ddd; color: #000; }
        .btn:disabled { opacity: 0.3; pointer-events: none; }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }

        /* CURRENT VIEWPORT */
        .viewport {
            background: #fff; border-radius: 25px; border: 1px solid var(--border);
            padding: 40px; text-align: center; margin-bottom: 30px;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);
        }
        .viewport h3 { font-size: 0.8rem; color: #999; margin-bottom: 10px; }
        .viewport #current-url { font-size: 1.5rem; font-weight: 600; color: var(--primary); }

        /* STACK VISUALIZER */
        .stack-area { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .stack-box {
            background: rgba(0,0,0,0.02); padding: 20px; border-radius: 20px;
            min-height: 250px; display: flex; flex-direction: column-reverse; gap: 10px;
        }
        .stack-title { font-size: 0.65rem; font-weight: 900; text-align: center; margin-bottom: 10px; color: #bbb; }

        .history-item {
            background: #fff; padding: 12px; border-radius: 10px; font-size: 0.8rem;
            border: 1px solid var(--border); box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            animation: pushAnim 0.3s ease; text-align: center;
        }
        @keyframes pushAnim { from { transform: scale(0.9); opacity: 0; } }

        /* FOOTER SPECS */
        .footer-specs {
            grid-column: span 2; margin-top: 40px; padding-top: 25px;
            border-top: 1px solid var(--border); display: flex; justify-content: space-between;
            font-family: monospace; font-size: 0.7rem; color: #bbb;
        }
    </style>
</head>
<body>

    <div id="custom-cursor"></div>

    <div class="engine-container">
        <div class="sidebar">
            <h1>Navigator_Engine</h1>
            <p>// LIFO_STACK_CORE_v1.0 //</p>
            
            <div class="nav-controls">
                <label>Target URL</label>
                <input type="text" id="urlInput" placeholder="https://google.com">
                <button class="btn btn-push" onclick="visit()">VISIT_URL [PUSH]</button>
                
                <div class="btn-group" style="margin-top: 20px;">
                    <button class="btn btn-nav" id="backBtn" onclick="goBack()" disabled>BACK [POP]</button>
                    <button class="btn btn-nav" id="fwdBtn" onclick="goForward()" disabled>FORWARD</button>
                </div>
            </div>

            <div style="margin-top: 40px; padding: 20px; background: rgba(0,0,0,0.03); border-radius: 15px;">
                <p style="font-size: 0.75rem; color: #777; line-height: 1.6;">
                    <b>Algorithm Note:</b> Navigation uses a <b>Last-In-First-Out (LIFO)</b> structure. 
                    Visiting a new page clears the Forward Stack to maintain history consistency.
                </p>
            </div>
        </div>

        <div class="main-content">
            <div class="viewport">
                <h3>ACTIVE_VIEWPORT [PEEK]</h3>
                <div id="current-url">EMPTY_SESSION</div>
            </div>

            <div class="stack-area">
                <div>
                    <div class="stack-title">BACK_STACK [HISTORY]</div>
                    <div class="stack-box" id="backStack"></div>
                </div>
                <div>
                    <div class="stack-title">FORWARD_STACK</div>
                    <div class="stack-box" id="fwdStack"></div>
                </div>
            </div>

            <div class="footer-specs">
                <span>SYSTEM_STATUS: NOMINAL</span>
                <span>DATA_LOC: NAGPUR_ENGINEERING_LAB</span>
                <span>DEV: STUDENT_ID_SIT_NAGPUR</span>
            </div>
        </div>
    </div>

    <script>
        const dot = document.getElementById('custom-cursor');
        document.addEventListener('mousemove', (e) => {
            dot.style.left = e.clientX + 'px';
            dot.style.top = e.clientY + 'px';
        });

        // DUAL STACK LOGIC
        let historyStack = []; // Back
        let forwardStack = []; // Forward
        let currentURL = null;

        function render() {
            document.getElementById('current-url').innerText = currentURL || "EMPTY_SESSION";
            
            const bStackDiv = document.getElementById('backStack');
            const fStackDiv = document.getElementById('fwdStack');
            
            bStackDiv.innerHTML = historyStack.map(url => `<div class="history-item">${url}</div>`).join('');
            fStackDiv.innerHTML = forwardStack.map(url => `<div class="history-item">${url}</div>`).join('');

            document.getElementById('backBtn').disabled = historyStack.length === 0;
            document.getElementById('fwdBtn').disabled = forwardStack.length === 0;
        }

        function visit() {
            const url = document.getElementById('urlInput').value.trim();
            if (!url) return;

            if (currentURL) {
                historyStack.push(currentURL); // Push current to back stack
            }
            currentURL = url;
            forwardStack = []; // Clear forward stack on new visit
            document.getElementById('urlInput').value = "";
            render();
        }

        function goBack() {
            if (historyStack.length === 0) return;
            forwardStack.push(currentURL); // Push current to forward
            currentURL = historyStack.pop(); // Pop from back
            render();
        }

        function goForward() {
            if (forwardStack.length === 0) return;
            historyStack.push(currentURL); // Push current to back
            currentURL = forwardStack.pop(); // Pop from forward
            render();
        }

        // CURSOR INTERACTION
        document.addEventListener('mouseover', (e) => {
            if(e.target.tagName === 'BUTTON' || e.target.tagName === 'INPUT') {
                dot.style.transform = 'translate(-50%, -50%) scale(4)';
                dot.style.background = 'transparent';
                dot.style.border = '1px solid var(--primary)';
            } else {
                dot.style.transform = 'translate(-50%, -50%) scale(1)';
                dot.style.background = 'var(--primary)';
                dot.style.border = 'none';
            }
        });

        render();
    </script>
</body>
</html>  
