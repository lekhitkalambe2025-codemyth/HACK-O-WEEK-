<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symbi_Library | Catalog Terminal</title>
    <style>
        :root { 
            --accent: #000000; 
            --bg-gradient: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
            --glass: rgba(255, 255, 255, 0.6);
            --border: rgba(0, 0, 0, 0.08);
            --warn: #d63031;
            --success: #00b894;
        }
        
        /* HIDE DEFAULT CURSOR */
        * { cursor: none !important; margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            background: var(--bg-gradient); 
            color: #2d3436; 
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        /* NEON BLACK DOT CURSOR */
        #custom-cursor {
            width: 8px; height: 8px; background: #000; border-radius: 50%;
            position: fixed; pointer-events: none; z-index: 10001;
            transform: translate(-50%, -50%); box-shadow: 0 0 10px rgba(0,0,0,0.2);
            transition: transform 0.1s ease-out;
        }

        .terminal {
            width: 1000px;
            background: var(--glass);
            backdrop-filter: blur(25px);
            border: 1px solid var(--border);
            border-radius: 30px;
            padding: 50px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.05);
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 40px;
        }

        /* LEFT PANEL: CONTROLS */
        .controls h1 { font-size: 1.5rem; letter-spacing: 5px; margin-bottom: 5px; font-weight: 800; text-transform: uppercase; }
        .controls p { font-size: 0.7rem; color: #888; font-family: monospace; margin-bottom: 30px; }

        .input-group { margin-bottom: 20px; }
        label { display: block; font-size: 0.65rem; letter-spacing: 2px; color: #999; margin-bottom: 8px; text-transform: uppercase; }
        
        input {
            width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px;
            background: white; color: #000; outline: none; transition: 0.3s;
            font-size: 0.9rem;
        }
        input:focus { border-color: var(--accent); box-shadow: 0 0 15px rgba(0,0,0,0.05); }

        .btn {
            width: 100%; padding: 15px; border: none; border-radius: 12px;
            font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
            transition: 0.3s; margin-top: 10px;
        }
        .btn-add { background: var(--accent); color: #fff; }
        .btn-add:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .btn-add:disabled { background: #ccc; transform: none; box-shadow: none; opacity: 0.5; }

        /* CAPACITY MONITOR */
        .capacity-bar {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }
        .bar-bg { height: 6px; background: #eee; border-radius: 3px; margin-top: 10px; overflow: hidden; }
        #bar-fill { height: 100%; width: 0%; background: var(--accent); transition: 0.5s ease; }

        /* RIGHT PANEL: CATALOG */
        .catalog-box { 
            background: rgba(255,255,255,0.4); 
            border-radius: 20px; 
            padding: 25px; 
            height: 500px; 
            overflow-y: auto;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .book-item {
            background: white; padding: 18px 25px; border-radius: 15px;
            margin-bottom: 15px; display: flex; justify-content: space-between;
            align-items: center; border: 1px solid transparent;
            animation: slideIn 0.4s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }
        .book-item:hover { border-color: #eee; transform: translateX(5px); transition: 0.3s; }
        .book-info h3 { font-size: 0.95rem; font-weight: 700; color: #000; }
        .book-info p { font-size: 0.75rem; color: #888; font-style: italic; }

        .btn-del { color: var(--warn); background: none; border: none; font-family: monospace; font-weight: bold; padding: 5px; }
        .btn-del:hover { text-decoration: underline; }

        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } }

        #search-status { font-size: 0.7rem; color: var(--success); font-family: monospace; margin-top: 10px; }

        /* Scrollbar Styling */
        .catalog-box::-webkit-scrollbar { width: 5px; }
        .catalog-box::-webkit-scrollbar-thumb { background: #ddd; border-radius: 10px; }
    </style>
</head>
<body>

    <div id="custom-cursor"></div>

    <div class="terminal">
        <div class="controls">
            <h1>BIBLIOTHECA</h1>
            <p>// ARRAY_STORAGE: FIXED_CAP_10 //</p>

            <div class="input-group">
                <label>System Search</label>
                <input type="text" id="searchTitle" placeholder="Filter Title..." oninput="searchBooks()">
                <div id="search-status">STATUS: LISTING_ALL</div>
            </div>

            <div class="input-group" style="margin-top: 40px; border-top: 1px solid #eee; padding-top: 20px;">
                <label>Add New Entry</label>
                <input type="text" id="newBook" placeholder="Book Title">
                <input type="text" id="newAuthor" placeholder="Author Name" style="margin-top: 10px;">
                <button class="btn btn-add" id="addBtn" onclick="addBook()">EXECUTE_ADD</button>
            </div>

            <div class="capacity-bar">
                <label>Storage Load: <span id="cap-text">0/10</span></label>
                <div class="bar-bg"><div id="bar-fill"></div></div>
            </div>
        </div>

        <div class="catalog-box" id="bookDisplay">
            </div>
    </div>

    <script>
        // SIGNATURE CURSOR LOGIC
        const dot = document.getElementById('custom-cursor');
        document.addEventListener('mousemove', (e) => {
            dot.style.left = e.clientX + 'px';
            dot.style.top = e.clientY + 'px';
        });

        // FIXED SIZE ARRAY LOGIC (MAX 10)
        const MAX_CAPACITY = 10;
        let books = [
            { title: "C++ Programming Principles", author: "Bjarne Stroustrup" },
            { title: "Digital Design & DELD", author: "M. Morris Mano" },
            { title: "Python Algorithm Analysis", author: "Guido van Rossum" }
        ];

        // RENDER FUNCTION
        function renderBooks(filter = "") {
            const display = document.getElementById('bookDisplay');
            const searchStatus = document.getElementById('search-status');
            display.innerHTML = "";

            // Implementation of the search by title
            const filtered = books.filter(b => b.title.toLowerCase().includes(filter.toLowerCase()));
            
            searchStatus.innerText = filter ? `MATCHES_FOUND: ${filtered.length}` : "STATUS: LISTING_ALL";

            filtered.forEach((book) => {
                const originalIndex = books.indexOf(book);
                const div = document.createElement('div');
                div.className = 'book-item';
                div.innerHTML = `
                    <div class="book-info">
                        <h3>${book.title}</h3>
                        <p>${book.author}</p>
                    </div>
                    <button class="btn-del" onclick="removeBook(${originalIndex})">[REMOVE]</button>
                `;
                display.appendChild(div);
            });

            updateUI();
        }

        // ADD BOOK FUNCTION (WITH CAPACITY LIMITS)
        function addBook() {
            const title = document.getElementById('newBook').value.trim();
            const author = document.getElementById('newAuthor').value.trim();

            if (books.length >= MAX_CAPACITY) {
                alert("STORAGE_OVERFLOW: Maximum capacity (10) reached.");
                return;
            }

            if (title && author) {
                books.push({ title, author });
                document.getElementById('newBook').value = "";
                document.getElementById('newAuthor').value = "";
                renderBooks();
            }
        }

        // REMOVE BOOK FUNCTION
        function removeBook(index) {
            books.splice(index, 1);
            renderBooks();
        }

        // SEARCH INPUT TRIGGER
        function searchBooks() {
            const query = document.getElementById('searchTitle').value;
            renderBooks(query);
        }

        // MONITOR UI UPDATE
        function updateUI() {
            const count = books.length;
            document.getElementById('cap-text').innerText = `${count}/${MAX_CAPACITY}`;
            
            const fill = document.getElementById('bar-fill');
            fill.style.width = (count / MAX_CAPACITY * 100) + "%";
            
            // Color feedback for capacity
            if(count >= MAX_CAPACITY) fill.style.background = "#d63031";
            else fill.style.background = "#000";

            document.getElementById('addBtn').disabled = (count >= MAX_CAPACITY);
        }

        // INITIAL RENDER
        renderBooks();

        // CURSOR INTERACTION SCALING
        document.addEventListener('mouseover', (e) => {
            if(e.target.tagName === 'BUTTON' || e.target.tagName === 'INPUT' || e.target.closest('.book-item')) {
                dot.style.transform = 'translate(-50%, -50%) scale(4)';
                dot.style.background = 'transparent';
                dot.style.border = '1px solid #000';
            } else {
                dot.style.transform = 'translate(-50%, -50%) scale(1)';
                dot.style.background = '#000';
                dot.style.border = 'none';
            }
        });
    </script>
</body>
</html>
